HOST=0.0.0.0
PORT=1337
APP_KEYS=toBeModified1,toBeModified2
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
ENCRYPTION_KEY=tobemodified

# Local dev (SQLite)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Production (Railway PostgreSQL)
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/strapi

# Default CMS locale (Spanish)
STRAPI_PLUGIN_I18N_INIT_LOCALE_CODE=es

# Webhook to rebuild Vercel on publish
VERCEL_DEPLOY_HOOK_URL=

# Allowed CORS origin for Next.js frontend (production URL)
FRONTEND_URL=https://jorgedesmond.com
