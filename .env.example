# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Strapi (optional — falls back to mock data when STRAPI_URL is unset)
# Must be set at build time on Vercel so images and API fetches resolve correctly.
STRAPI_URL=http://localhost:1337
# Public reads work without a token when Strapi permissions allow it.
# Required in production for blog comments (create, vote, report).
# Create a Custom token in Strapi with ONLY: comment → find, findOne, create, update
# Do NOT use Full Access or Read-only.
STRAPI_API_TOKEN=

# Vercel deploy hook (set in Strapi webhook)
VERCEL_DEPLOY_HOOK_URL=

# Instagram Graph API — ilustraciones en /ilustracion (https://www.instagram.com/sr.dsmd/)
# Requiere cuenta Creator/Business vinculada a una app de Meta.
# IMPORTANTE: van en Vercel → Settings → Environment Variables (Production), NO en strapi/.env
# INSTAGRAM_USER_ID = ID numérico de la cuenta (ej. 17841408364851001)
# Genera el token en Meta Developers → Instagram → Generate access tokens
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
