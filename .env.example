# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Strapi (optional — falls back to mock data when STRAPI_URL is unset)
# Must be set at build time on Vercel so images and API fetches resolve correctly.
STRAPI_URL=http://localhost:1337
# Optional locally if public read permissions are enabled; required in production
# and for blog comments (create, vote, report)
STRAPI_API_TOKEN=

# Vercel deploy hook (set in Strapi webhook)
VERCEL_DEPLOY_HOOK_URL=

# Instagram Graph API — ilustraciones en /ilustracion (https://www.instagram.com/sr.dsmd/)
# Requiere cuenta Creator/Business vinculada a una app de Meta.
# IMPORTANTE: van en este archivo (.env.local en la raíz), NO en strapi/.env
# Docs: https://developers.facebook.com/docs/instagram-platform
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
